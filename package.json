{
  "name": "eslint-plugin-jest-dom",
  "version": "0.0.0-semantically-released",
  "description": "ESLint plugin to follow best practices and anticipate common mistakes when writing tests with jest-dom",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "jest-dom",
    "testing-library",
    "react-testing-library",
    "dom-testing-library",
    "RTL",
    "DTL",
    "tests"
  ],
  "homepage": "https://github.com/testing-library/eslint-plugin-jest-dom#readme",
  "bugs": {
    "url": "https://github.com/testing-library/eslint-plugin-jest-dom/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/testing-library/eslint-plugin-jest-dom"
  },
  "license": "MIT",
  "author": "Ben Monro",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "docs",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup --config",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "pregenerate-readme-table": "npm run build",
    "generate-readme-table": "eslint-doc-generator",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "lint:generate-readme-table": "npm run generate-readme-table -- --check",
    "lint:remote": "eslint-remote-tester --config smoke-test/eslint-remote-tester.config.js",
    "setup": "npm install && npm run validate",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./jest.config.js --runInBand",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test:coverage -- --updateSnapshot",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run lint:generate-readme-table && npm run format"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@homer0/prettier-plugin-jsdoc": "^11.1.0",
    "@testing-library/dom": "^10.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-doc-generator": "^3.3.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-remote-tester": "^4.0.4",
    "eslint-remote-tester-repositories": "^2.0.2",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "rollup": "^4.60.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@testing-library/dom": "^10.0.0",
    "eslint": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@testing-library/dom": {
      "optional": true
    }
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
